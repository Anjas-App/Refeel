{
  "expo": {
    "name": "Refeel",
    "slug": "refeel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#f2fadd"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.refeel.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#f2fadd"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.refeel.app"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "enableHermes": false
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "google": {
        "androidClientId": "1091265885126-hpmhp9rt62e96lm7l4mj404jkl3dav49.apps.googleusercontent.com",
        "iosClientId": "YOUR_GOOGLE_IOS_CLIENT_ID",
        "webClientId": "YOUR_GOOGLE_WEB_CLIENT_ID",
        "expoClientId": "YOUR_GOOGLE_EXPO_CLIENT_ID"
      },
      "eas": {
        "projectId": "4e49b025-e9b4-41de-84e3-027f3d65ecda"
      }
    },
    "owner": "a.wie",
    "sdkVersion": "53.0.0",
    "platforms": [
      "ios",
      "android"
    ]
  }
}
